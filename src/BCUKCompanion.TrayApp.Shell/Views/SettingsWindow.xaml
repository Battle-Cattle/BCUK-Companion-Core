<Window x:Class="BCUKCompanion.TrayApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BCUK Companion — Settings"
        Width="440" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <TextBlock Grid.Row="1" Text="Bot server URL" FontWeight="SemiBold" />
        <TextBlock Grid.Row="2" x:Name="BotHostText" Margin="0,4,0,4" />
        <TextBlock Grid.Row="3" Text="Log out to switch to a different server." Foreground="Gray" FontSize="11" Margin="0,0,0,12" />

        <CheckBox Grid.Row="4" x:Name="StartWithWindowsCheckBox" Content="Start automatically when Windows starts" />

        <TextBlock Grid.Row="5" x:Name="ConnectionStatusText" Margin="0,16,0,0" FontWeight="SemiBold" />

        <TextBlock Grid.Row="6" x:Name="StatusText" Foreground="Gray" TextWrapping="Wrap" Margin="0,8,0,0" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="LogOutButton" Content="Log Out" Width="90" Margin="0,0,8,0" Click="LogOutButton_Click" />
            <Button x:Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="SaveButton_Click" />
            <Button x:Name="CloseButton" Content="Close" Width="90" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
