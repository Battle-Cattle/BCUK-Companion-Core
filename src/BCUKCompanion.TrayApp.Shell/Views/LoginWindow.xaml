<Window x:Class="BCUKCompanion.TrayApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BCUK Companion — Login"
        Width="420" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sign in to BCUK Companion" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <Button Grid.Row="1" x:Name="LoginWithBrowserButton" Content="Login with Discord (opens browser)"
                Height="32" Click="LoginWithBrowserButton_Click" />

        <TextBlock Grid.Row="2" Text="— or paste a token from the dashboard's Companion App page —"
                   Margin="0,16,0,8" TextWrapping="Wrap" Foreground="Gray" />

        <PasswordBox Grid.Row="3" x:Name="TokenBox" Height="28" />

        <Button Grid.Row="4" x:Name="SaveTokenButton" Content="Save Token" Height="32" Margin="0,8,0,0"
                Click="SaveTokenButton_Click" />

        <TextBlock Grid.Row="5" x:Name="StatusText" Foreground="Red" TextWrapping="Wrap" Margin="0,12,0,0" />

        <TextBlock Grid.Row="6" Text="Server" FontWeight="SemiBold" Margin="0,8,0,4" />

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="ServerHostBox" Height="26" Margin="0,0,8,0"
                     AutomationProperties.Name="Server URL" />
            <Button Grid.Column="1" x:Name="ChangeServerButton" Content="Change" Width="70"
                    AutomationProperties.Name="Change server URL"
                    Click="ChangeServerButton_Click" />
        </Grid>

        <TextBlock Grid.Row="8" x:Name="ServerStatusText" Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />
    </Grid>
</Window>
